<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.PreviewFragment">

    <!-- 照片预览区域（标题栏下方到工具栏上方） -->
    <ImageView
        android:id="@+id/image_preview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toTopOf="@+id/toolbar_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_bar" />

    <!-- 水印覆盖层（平铺 mypx 文字） -->
    <com.mary.mypx.feature.camera.ui.WatermarkOverlayView
        android:id="@+id/watermark_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/toolbar_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_bar" />

    <!-- 裁剪覆盖层（裁剪模式时显示） -->
    <com.mary.mypx.feature.camera.ui.CropOverlayView
        android:id="@+id/crop_overlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/toolbar_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_bar" />

    <!-- 顶部标题栏（覆盖在图片上方） -->
    <LinearLayout
        android:id="@+id/title_bar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#CC000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 返回按钮 -->
        <ImageButton
            android:id="@+id/button_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            app:tint="@android:color/white" />

        <!-- 标题文字 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Photo"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 应用按钮 -->
        <ImageButton
            android:id="@+id/button_apply"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Apply"
            android:src="@drawable/ic_check"
            app:tint="@android:color/white" />

        <!-- 更多按钮（三个点） -->
        <ImageButton
            android:id="@+id/button_more"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More"
            android:src="@drawable/ic_more_vert"
            app:tint="@android:color/white" />

    </LinearLayout>

    <!-- 对比按钮（按住显示原图，松开显示编辑后） -->
    <!-- 放在图片区域内右下角 -->
    <ImageButton
        android:id="@+id/compare_button"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/compare_button_bg"
        android:contentDescription="Compare"
        android:elevation="4dp"
        android:padding="8dp"
        android:src="@drawable/ic_compare"
        app:layout_constraintBottom_toTopOf="@+id/toolbar_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@android:color/white" />

    <!-- 工具栏容器（始终显示，保持布局稳定） -->
    <FrameLayout
        android:id="@+id/toolbar_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#E6000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 主工具栏 -->
        <LinearLayout
            android:id="@+id/main_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="32dp">

            <!-- 工具栏（水平滚动） -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- 预设 -->
                <LinearLayout
                    android:id="@+id/tool_presets"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="Presets"
                        android:src="@drawable/ic_tune"
                        app:tint="@android:color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Presets"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- 色彩调节 -->
                <LinearLayout
                    android:id="@+id/tool_color"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="Color"
                        android:src="@drawable/ic_palette"
                        app:tint="@android:color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Color"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- 人像美化 -->
                <LinearLayout
                    android:id="@+id/tool_beauty"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="Beauty"
                        android:src="@drawable/ic_face"
                        app:tint="@android:color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Beauty"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- 裁剪旋转（带 free 标记） -->
                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:padding="4dp">

                    <LinearLayout
                        android:id="@+id/tool_crop"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="Crop"
                            android:src="@drawable/ic_crop"
                            app:tint="@android:color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Crop"
                            android:textColor="@android:color/white"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- free 标记 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:text="free"
                        android:textColor="#FF9800"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                </FrameLayout>

                <!-- 换天空 -->
                <LinearLayout
                    android:id="@+id/tool_sky"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="Sky"
                        android:src="@drawable/ic_sunny"
                        app:tint="@android:color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Sky"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                </LinearLayout>

                <!-- 衣物美化 -->
                <LinearLayout
                    android:id="@+id/tool_clothes"
                    android:layout_width="72dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="Clothes"
                        android:src="@drawable/ic_checkroom"
                        app:tint="@android:color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Clothes"
                        android:textColor="@android:color/white"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

        </HorizontalScrollView>

        </LinearLayout>

        <!-- 裁剪工具栏（裁剪模式时覆盖显示） -->
        <LinearLayout
            android:id="@+id/crop_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E6000000"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="32dp"
            android:visibility="gone">

        <!-- 取消按钮 -->
        <ImageButton
            android:id="@+id/button_crop_cancel"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cancel"
            android:src="@drawable/ic_close"
            app:tint="@android:color/white" />

        <!-- 标题 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Crop"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <!-- 确认按钮 -->
        <ImageButton
            android:id="@+id/button_crop_confirm"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Confirm"
            android:src="@drawable/ic_check"
            app:tint="@android:color/white" />

    </LinearLayout>

    </FrameLayout>

    <!-- 处理时间显示 -->
    <TextView
        android:id="@+id/text_processing_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#80000000"
        android:padding="8dp"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_bar" />

</androidx.constraintlayout.widget.ConstraintLayout>
