<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.CameraFragment">

    <!-- 
        美颜 TextureView
        使用 OpenGL 渲染，实时显示美颜效果
    -->
    <com.mary.mypx.sdk.BeautyTextureView
        android:id="@+id/beauty_texture_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/beauty_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 美颜控制区域 -->
    <LinearLayout
        android:id="@+id/beauty_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toTopOf="@+id/controls_layout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 美颜标签 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="美颜"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <!-- 美颜强度进度条 -->
        <SeekBar
            android:id="@+id/seekbar_beauty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:max="100"
            android:progress="50"
            android:progressTint="@android:color/holo_purple"
            android:thumbTint="@android:color/holo_purple" />

        <!-- 强度数值显示 -->
        <TextView
            android:id="@+id/text_beauty_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:minWidth="40dp"
            android:gravity="end" />

    </LinearLayout>

    <!-- 控制按钮区域 -->
    <LinearLayout
        android:id="@+id/controls_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#CC000000"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- 闪光灯按钮 -->
        <ImageButton
            android:id="@+id/button_flash"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle Flash"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="@android:color/white" />

        <!-- 拍照按钮 -->
        <ImageButton
            android:id="@+id/button_take_photo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:background="@drawable/circle_background"
            android:contentDescription="Take Photo"
            android:src="@android:drawable/ic_menu_camera"
            app:tint="@android:color/white" />

        <!-- 切换摄像头按钮 -->
        <ImageButton
            android:id="@+id/button_switch_camera"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Switch Camera"
            android:src="@android:drawable/ic_menu_rotate"
            app:tint="@android:color/white" />

    </LinearLayout>

    <!-- 性能监控显示 -->
    <TextView
        android:id="@+id/text_performance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#80000000"
        android:padding="8dp"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
